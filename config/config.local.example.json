{
  "app": {
    "name": "AI Novel Studio",
    "version": "0.1.0",
    "env": "local"
  },
  "database": {
    "provider": "sqlite",
    "url": "file:./data/novel-studio.db"
  },
  "storage": {
    "provider": "local",
    "basePath": "./data/storage"
  },
  "ai": {
    "providers": [
      {
        "name": "openai",
        "enabled": true,
        "apiKey": "${OPENAI_API_KEY}",
        "models": ["gpt-4", "gpt-3.5-turbo"]
      },
      {
        "name": "anthropic",
        "enabled": true,
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": ["claude-3-opus", "claude-3-sonnet"]
      },
      {
        "name": "local",
        "enabled": true,
        "endpoint": "http://localhost:11434",
        "models": ["llama2", "codellama"]
      }
    ],
    "defaultProvider": "openai",
    "defaultModel": "gpt-4"
  },
  "workflow": {
    "maxConcurrency": 3,
    "timeout": 60000,
    "retryAttempts": 3
  },
  "server": {
    "port": 3000,
    "host": "localhost"
  },
  "logging": {
    "level": "info",
    "file": "./logs/app.log"
  }
}
